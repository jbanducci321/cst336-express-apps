<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>

</head>
<body>
    <h1 class="bg-info text-white p-3 m-0"> The Solar System </h1>

    <nav class="navbar navbar-expand-lg bg-body-tertiary">
  <%- include("partials/nav.ejs") %>
</nav>
    <h2><%= planet %></h2>
    <div class="container-fluid m-5 row">

        <div class="p-4 col">
            <%= planetInfo.description %> <br><hr>
            <p>Distance from sun: <%= planetInfo.distanceFromSun %></p>
            <p>Year length: <%= planetInfo.yearLength %></p>
            <p>Radius: <%= planetInfo.radius %></p>
            <p>Number of moons: <%= planetInfo.moons %></p>
            <p>Length of one Earth day: <%= planetInfo.oneEarthDay %></p>
        </div>
        
        <div class="card col">
            <img src="<%= planetInfo.image %>">
        </div>
    </div>

    <footer>
      <%- include("partials/footer.ejs") %>
    </footer>
</body>
</html>